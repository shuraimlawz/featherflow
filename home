<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>E-Storefront - FeatherFlow</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <header>
        <div class="nav-container">
            <div class="logo"><h1>Feather<span>Flow</span></h1></div>
            <nav>
                <ul>
                    <li><a href="index.html">Welcome</a></li>
                    <li><a href="home.html" class="active">Shop Front</a></li>
                    <li><a href="contact.html">Contact Us</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main class="container">
        <h2 style="color: var(--primary-color); border-bottom: 2px solid var(--border-color); padding-bottom: 0.5rem;">Available Farm Stocks</h2>
        
        <div class="product-grid">
            <!-- Product 1 -->
            <div class="product-card">
                <div class="product-info">
                    <span class="product-category">Eggs</span>
                    <h3 class="product-title">Fresh Grade-A Farm Crates</h3>
                    <p style="color:#718096; font-size:0.9rem; margin-bottom:1rem;">Freshly collected healthy daily yields directly sourced from clean laying cycles.</p>
                    <div class="product-price">$4.50 <span style="font-size: 0.8rem; color:#718096;">/ Per Crate</span></div>
                    <button class="btn" style="width: 100%;">Add to Basket</button>
                </div>
            </div>

            <!-- Product 2 -->
            <div class="product-card">
                <div class="product-info">
                    <span class="product-category">Meat</span>
                    <h3 class="product-title">Premium Broiler Chicken (Dressed)</h3>
                    <p style="color:#718096; font-size:0.9rem; margin-bottom:1rem;">Hygienically clean processed broiler options optimized for standard culinary use.</p>
                    <div class="product-price">$12.00 <span style="font-size: 0.8rem; color:#718096;">/ Unit kg</span></div>
                    <button class="btn" style="width: 100%;">Add to Basket</button>
                </div>
            </div>

            <!-- Product 3 -->
            <div class="product-card">
                <div class="product-info">
                    <span class="product-category">Live Birds</span>
                    <h3 class="product-title">Healthy Layers (Active Mature)</h3>
                    <p style="color:#718096; font-size:0.9rem; margin-bottom:1rem;">Fully matured standard layout poultry choices perfect for local husbandry initialization.</p>
                    <div class="product-price">$15.50 <span style="font-size: 0.8rem; color:#718096;">/ Head Count</span></div>
                    <button class="btn" style="width: 100%;">Add to Basket</button>
                </div>
            </div>
        </div>
    </main>

    <footer>
        <p>&copy; 2026 FeatherFlow Systems. All Rights Reserved.</p>
    </footer>

<script src="app.js"></script>
</body>
</html>
