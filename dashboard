<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - FeatherFlow</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <header>
        <div class="nav-container">
            <div class="logo"><h1>Feather<span>Flow</span> Admin</h1></div>
            <nav>
                <ul>
                    <li><a href="index.html">Welcome</a></li>
                    <li><a href="home.html">Shop Front</a></li>
                    <li><a href="dashboard.html" class="active">Dashboard</a></li>
                    <li><a href="contact.html">Contact Us</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main class="container">
        <h2 style="color: var(--primary-color); margin-bottom: 2rem; border-bottom: 2px solid var(--border-color); padding-bottom: 0.5rem;">
            Poultry Operations Control Panel
        </h2>

        <!-- Admin Quick Stats Summary Grid -->
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; margin-bottom: 3rem;">
            <div class="product-card" style="padding: 1.5rem; text-align: center; border-left: 5px solid var(--primary-color);">
                <span style="color: #718096; font-weight: 600; font-size: 0.9rem;">TOTAL ACTIVE FLOCK</span>
                <h3 style="font-size: 2rem; color: var(--primary-color); margin-top: 0.5rem;">1,240 Birds</h3>
            </div>
            <div class="product-card" style="padding: 1.5rem; text-align: center; border-left: 5px solid var(--secondary-color);">
                <span style="color: #718096; font-weight: 600; font-size: 0.9rem;">DAILY YIELD EFFICIENCY</span>
                <h3 style="font-size: 2rem; color: var(--secondary-color); margin-top: 0.5rem;">94.2%</h3>
            </div>
            <div class="product-card" style="padding: 1.5rem; text-align: center; border-left: 5px solid var(--accent-color);">
                <span style="color: #718096; font-weight: 600; font-size: 0.9rem;">PENDING WEB ORDERS</span>
                <h3 style="font-size: 2rem; color: var(--accent-color); margin-top: 0.5rem;">8 Orders</h3>
            </div>
        </div>

        <!-- Management Forms Split Section -->
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(450px, 1fr)); gap: 2rem;">
            
            <!-- Form 1: Daily Egg Production Log -->
            <div class="form-box" style="margin: 0; max-width: 100%;">
                <h3 style="color: var(--primary-color); margin-bottom: 1.5rem;">🥚 Log Daily Egg Yield</h3>
                <form id="eggLogForm">
                    <div class="form-group">
                        <label for="flockId">Select Target Flock Batch</label>
                        <select id="flockId" required>
                            <option value="FLK-001">Flock 001 - White Leghorn (Laying)</option>
                            <option value="FLK-002">Flock 002 - Rhode Island Red (Laying)</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="goodEggs">Healthy Eggs (Good Quantity)</label>
                        <input type="number" id="goodEggs" min="0" placeholder="e.g. 350" required>
                    </div>
                    <div class="form-group">
                        <label for="damagedEggs">Cracked / Undersized Eggs</label>
                        <input type="number" id="damagedEggs" min="0" placeholder="e.g. 12" required>
                    </div>
                    <button type="submit" class="btn" style="width: 100%; background-color: var(--primary-color);">Commit Yield Log Entry</button>
                </form>
            </div>

            <!-- Form 2: Product Inventory Stock Posting -->
            <div class="form-box" style="margin: 0; max-width: 100%;">
                <h3 style="color: var(--secondary-color); margin-bottom: 1.5rem;">🛍️ Sync E-Store Product Catalog</h3>
                <form id="productStockForm">
                    <div class="form-group">
                        <label for="prodName">Product Commercial Name</label>
                        <input type="text" id="prodName" placeholder="e.g. Fresh Organic Crates (Jumbo)" required>
                    </div>
                    <div class="form-group">
                        <label for="prodCat">Inventory Category</label>
                        <select id="prodCat">
                            <option value="Eggs">Eggs</option>
                            <option value="Meat">Meat</option>
                            <option value="Live">Live Birds</option>
                            <option value="Fertilizer">Organic Fertilizer</option>
                        </select>
                    </div>
                    <div class="form-group" style="display: flex; gap: 1rem;">
                        <div style="flex: 1;">
                            <label for="prodPrice">Unit Price ($)</label>
                            <input type="number" id="prodPrice" step="0.01" min="0.00" placeholder="4.50" required>
                        </div>
                        <div style="flex: 1;">
                            <label for="prodStock">Initial Stock Quantity</label>
                            <input type="number" id="prodStock" min="0" placeholder="150" required>
                        </div>
                    </div>
                    <button type="submit" class="btn" style="width: 100%;">Push Product Live</button>
                </form>
            </div>

        </div>
    </main>

    <footer>
        <p>&copy; 2026 FeatherFlow Systems. All Rights Reserved.</p>
    </footer>

    <script src="app.js"></script>
    <script>
        // Inline layout handling for Admin Mock Interactivity
        document.getElementById('eggLogForm').addEventListener('submit', (e) => {
            e.preventDefault();
            alert('Operation Successful: Daily production parameters written cleanly into the system logs database array layout.');
            e.target.reset();
        });

        document.getElementById('productStockForm').addEventListener('submit', (e) => {
            e.preventDefault();
            alert('Catalog Sync: Structured product metrics validated and synchronized to backend data relational models successfully.');
            e.target.reset();
        });
    </script>
    <script src="app.js"></script>
</body>
</html>
